# ── Railway Environment Variables Template ────────────────────────────────────
# Copy these into Railway → Project → Variables
# DO NOT commit a filled-in .env file

# Required: path to persistent SQLite database on Railway Volume
WEATHER1_DB_PATH=/data/weather1.db

# Required: enable the scheduler for shadow monitoring
SCHEDULER_ENABLED=true

# Required: set to production on Railway
APP_ENV=production

# Optional: CORS allowed origins (comma-separated)
# Add your frontend URL if you deploy the frontend separately
# e.g. https://weather1.vercel.app
CORS_ORIGINS=http://localhost:3000

# Logging level (INFO recommended for Railway)
LOG_LEVEL=INFO

# Polymarket API base URLs (read-only — no auth required for market data)
# [NEEDS_CHECK] Verify these are still current before production use
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_BASE_URL=https://data-api.polymarket.com

# Weather APIs
NWS_API_BASE_URL=https://api.weather.gov
OPEN_METEO_BASE_URL=https://api.open-meteo.com

# ── NEVER ADD THESE ON RAILWAY ────────────────────────────────────────────────
# WALLET_PRIVATE_KEY   ← no private keys in Phase 6G (or any phase before 8)
# POLYMARKET_API_KEY   ← no auth keys in Phase 6G
