# ── Weather1 Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in values.
# NEVER commit .env to git.
# No private keys or wallet mnemonics in Phase 1–7.

# ── Backend ───────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Polymarket API (read-only, Phase 2+) ─────────────────────────────────────
# NEEDS_CHECK: verify current base URLs before Phase 2
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_BASE_URL=https://data-api.polymarket.com

# ── Weather APIs (Phase 4+) ───────────────────────────────────────────────────
# NWS API: no key required
NWS_API_BASE_URL=https://api.weather.gov
# NOAA CDO API: free token from https://www.ncdc.noaa.gov/cdo-web/token
NOAA_CDO_API_TOKEN=
# Open-Meteo: no key required
OPEN_METEO_BASE_URL=https://api.open-meteo.com

# ── NO PRIVATE KEYS IN PHASE 1-7 ─────────────────────────────────────────────
# WALLET_PRIVATE_KEY=  ← DO NOT ADD UNTIL PHASE 8, BURNER WALLET ONLY
# POLYMARKET_API_KEY=  ← DO NOT ADD UNTIL PHASE 8
